rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Main collection helper rules
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidGroup(data) {
      return data.id is string
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.currency is string
        && data.currency.size() <= 5
        && data.friends is list
        && data.friends.size() <= 100
        && data.expenses is list
        && data.expenses.size() <= 1000;
    }

    // Rules for shared groups
    match /groups/{groupId} {
      // Anyone can fetch a group if they have its ID (allows shared links/shortcodes across devices smoothly)
      allow get: if true;
      allow list: if true;
      
      allow create: if isValidId(groupId)
        && isValidGroup(request.resource.data);
        
      allow update: if isValidGroup(request.resource.data);
        
      allow delete: if true;
    }

    // Rules for finding groups by short code without listing everything
    match /syncCodes/{code} {
      allow get: if true;
      allow create, update: if isSignedIn()
        && isValidId(code)
        && request.resource.data.groupId is string;
    }
  }
}
